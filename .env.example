# ===== Agnes API (backend / Python) =====
# Copy this file to `.env` and fill in real values.
# Verified base URL: https://apihub.agnes-ai.com/v1  (NOT api.agnes.ai — that DNS does not resolve)
# Verified model id: agnes-2.0-flash  (lowercase, as returned by GET /v1/models)
AGNES_API_KEY=your-agnes-api-key-here
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash

# ===== Agnes API (frontend / Vite) =====
# Vite only bundles variables prefixed with VITE_ into the frontend build.
# These are required so the Android APK can call Agnes directly.
VITE_AGNES_API_KEY=your-agnes-api-key-here
VITE_AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
VITE_AGNES_MODEL=agnes-2.0-flash

# ===== Supabase (optional, only if you deploy the edge function) =====
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
