# ===== Agnes API (backend / Python) =====
# Copy this file to `.env` and fill in real values.
# Verified base URL: https://apihub.agnes-ai.com/v1
# Verified model id: agnes-2.0-flash  (lowercase)
AGNES_API_KEY=your-agnes-api-key-here
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash

# ===== Agnes API (frontend / Vite) =====
# Vite only bundles variables prefixed with VITE_ into the frontend build.
VITE_AGNES_API_KEY=your-agnes-api-key-here
VITE_AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
VITE_AGNES_MODEL=agnes-2.0-flash

# ===== Speech-to-Text (Whisper) =====
# Agnes does NOT expose a Whisper endpoint, so STT uses a separate
# OpenAI-compatible provider. Defaults below point to the official
# OpenAI API — replace STT_API_KEY with your own key.
#
# You can also use any OpenAI-compatible Whisper gateway:
#   - OpenAI:      https://api.openai.com/v1     (model: whisper-1)
#   - Groq:        https://api.groq.com/openai/v1 (model: whisper-large-v3)
#   - DeepInfra:   https://api.deepinfra.com/v1/openai (model: openai/whisper-large-v3)
STT_API_KEY=your-openai-or-compatible-api-key-here
STT_BASE_URL=https://api.openai.com/v1
STT_MODEL=whisper-1

# ===== Supabase (optional, only if you deploy the edge function) =====
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
